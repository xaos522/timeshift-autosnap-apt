#!/bin/bash
#original author: gobonja
#adapted for apt by Willi Mutschler (wmutschl)
#Major refactoring by Jean De Schacht (xaos522) with a little help from Gemini

# 1. Constants & Initialization
readonly CONF_FILE=/etc/timeshift-autosnap-apt.conf
readonly DATE_PATTERN="[0-9]{4}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}"
readonly SCRIPT_TAG="{timeshift-autosnap-apt}" # Forced namespace for safety
typeset -A CONFIG  # Associative array for O(1) lookups
DRY_RUN=false
DEBUG=false

# 2. Argument Parsing
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -d|--dry-run) DRY_RUN=true; shift ;;
        -v|--verbose) DEBUG=true; shift ;;
        -h|--help)
            echo "Usage: $0 [options]"
            echo "Options:"
            echo "  -d, --dry-run    Show what would happen without making changes"
            echo "  -v, --verbose    Show loaded configuration and debug info"
            echo "  -h, --help       Show this help message"
            exit 0 ;;
        *)
            echo "[WARNING] Ignore unrecognized option $1" >&2
            shift ;;
    esac
done

# 3. One-Pass parser
# Helper function: remove leading and trailing spaces from variable value
shopt -s extglob
trim() {
    # argument $1 is a variable name
    typeset -n nref=$1
    nref="${nref##+([[:space:]])}" # Trim leading
    nref="${nref%%+([[:space:]])}" # Trim trailing
}

# Parse configuration file and store results in an associative array
load_config() {
    if [[ -f "$CONF_FILE" ]]; then
        typeset -a CONF_LINES
        typeset  LINE key val
        # Non-greedy pattern to match a line in the conf file.
        # When a line has multiple = signs we only only want
        # the text before the first one as first capture group.
        VALID_LINE_PATTERN='^([^=]+)=(.*)$'
        mapfile -t CONF_LINES < "$CONF_FILE"
        for LINE in "${CONF_LINES[@]}"; do
            # Skip empty lines and comments
            [[ -z "$LINE" || "$LINE" =~ ^[[:space:]]*# ]] && continue
            # Split the line on '=' character, non-gready.
            if [[ "$LINE" =~ $VALID_LINE_PATTERN ]]; then {
                key="${BASH_REMATCH[1]}"
                val="${BASH_REMATCH[2]}"
                trim key
                trim val
                CONFIG["$key"]="$val"
            }
            else {
                # No match - no '=' sign in LINE.
                echo "[WARNING] ignoring line in conf file ${CONF_FILE} ..." 2>&1
                echo "[WARNING] $LINE" 2>&1
            }
            fi
        done
    else {
        echo "[ERROR] $CONF_FILE is not a regular file." >&2
        exit 1
    }
    fi
}

get_property() {
    typeset key="$1" type="$2" default="$3"
    typeset val="${CONFIG[$key]}"

    [[ -z "$val" ]] && val="$default"

    case "$type" in
        boolean) [[ "$val" =~ ^(true|false)$ ]] || val="$default" ;;
        integer) [[ "$val" =~ ^[0-9]+$ ]] || val="$default" ;;
        string)  [[ -n "$val" ]] || val="$default" ;;
    esac
    echo "$val"
}

load_config

# 4. Debug Output
if [[ "$DEBUG" == "true" ]]; then
    echo "--- DEBUG: Loaded Configuration ---"
    for k in "${!CONFIG[@]}"; do echo "  $k = ${CONFIG[$k]}"; done
    echo "-----------------------------------"
fi
unset k

[[ "$DRY_RUN" == "true" ]] && echo "--- DRY RUN MODE ACTIVE ---"

# 5. Load Properties into Variables
SKIP_SNAP=$(get_property "skipAutosnap" "boolean" "false")
SNAP_BOOT=$(get_property "snapshotBoot" "boolean" "false")
SNAP_EFI=$(get_property "snapshotEFI" "boolean" "false")
DELETE_OLD=$(get_property "deleteSnapshots" "boolean" "true")
MAX_SNAPS=$(get_property "maxSnapshots" "integer" "3")
UPDATE_GRUB=$(get_property "updateGrub" "boolean" "false")
USER_NOTE=$(get_property "snapshotDescription" "string" "created before software update.")

unset CONFIG

# The "Namespace Lock": DESCRIPTION always starts with SCRIPT_TAG
DESCRIPTION="$SCRIPT_TAG $USER_NOTE"

# 6. Safety Checks
[[ $(findmnt / -no fstype) == "overlay" ]] && { echo "==> skipping: Live CD mode."; exit 0; }
[[ -v SKIP_AUTOSNAP ]] && { echo "==> skipping: SKIP_AUTOSNAP env detected."; exit 0; }
[[ "$SKIP_SNAP" == "true" ]] && { echo "==> skipping: skipAutosnap enabled in config."; exit 0; }

# 7. Execution Logic
run_sync() {
    typeset src="$1" dest="$2"
    echo "==> Syncing $src to $dest..."
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "[DRY RUN] Would rsync $src to $dest"
    else
        mkdir -p "$dest" && rsync -au --delete "$src" "$dest"
    fi
}

[[ "$SNAP_BOOT" == "true" ]] && run_sync "/boot/" "/boot.backup/"
[[ "$SNAP_EFI" == "true" ]] && run_sync "/boot/efi/" "/boot.backup/efi/"

echo "==> Creating Timeshift snapshot..."
if [[ "$DRY_RUN" == "true" ]]; then
    echo "[DRY RUN] Would create snapshot: $DESCRIPTION"
else
    timeshift --create --comments "$DESCRIPTION"
    status=$?
    [[ $status -ne 0 ]] && {
        echo "[ERROR] timeshift --create failed..." >&2
        echo "  with return code $status." >&2
        echo "  perhaps timeshift is active?" >&2
        echo "  if so, wait for timeshift to stop and retry the software update." >&2
        exit 1
    }
fi

# Capturing the status of 'timeshift --list' is tricky
# Required for 'lastpipe' to work in a script
set +m
shopt -s lastpipe

# 8. Delete oldest autosnap snapshots
if [[ "$DELETE_OLD" == "true" ]]; then
    typeset -a AUTO_SNAPS=()
    typeset -i attempt=1
    typeset -i max_attempts=3
    typeset -i wait_seconds=10
    typeset ts_exit_code=1

    echo "==> Checking for old snapshots to remove..."

    while (( attempt <= max_attempts )); do

        # To capture the exit status of the timeshift --list command,
        # use a standard pipe instead of process substitution.
        # We grep specifically for the tag to select auto snapshots.
        timeshift --list | grep -F "$SCRIPT_TAG" | mapfile -t AUTO_SNAPS

        # Now PIPESTATUS[0] is accessible because it's no longer in a subshell
        ts_exit_code=${PIPESTATUS[0]}

        if [[ $ts_exit_code -eq 0 ]]; then
            break # Success! Exit the retry loop
        fi

        echo "[WARNING] Timeshift is busy or locked (Attempt $attempt of $max_attempts)." >&2
        if (( attempt < max_attempts )); then
            echo "          Retrying in $wait_seconds seconds..." >&2
            sleep $wait_seconds
        fi
        (( attempt++ ))
    done

    if [[ $ts_exit_code -ne 0 ]]; then
        echo "[ERROR] Could not access Timeshift list after $max_attempts attempts. Skipping removal of old snapshots." >&2
    else
        # Success logic
        NUM_TO_DELETE=$(( ${#AUTO_SNAPS[@]} - MAX_SNAPS ))

        if (( NUM_TO_DELETE > 0 )); then
            echo "==> Found ${#AUTO_SNAPS[@]} autosnaps. Deleting oldest $NUM_TO_DELETE..."
            for (( i=0; i<NUM_TO_DELETE; i++ )); do
                if [[ "${AUTO_SNAPS[i]}" =~ $DATE_PATTERN ]]; then
                    TIMESTAMP="${BASH_REMATCH[0]}"
                    if [[ "$DRY_RUN" == "true" ]]; then
                        echo "[DRY RUN] Would delete: $TIMESTAMP"
                    else
                        echo "==> Deleting: $TIMESTAMP"
                        timeshift --delete --snapshot "$TIMESTAMP"
                        status=$?
                        if [[ $status -ne 0 ]]; then {
                            echo "[WARNING]" >&2
                            echo "          timeshift --delete --snapshot ${BASH_REMATCH[0]} failed..." >&2
                            echo "          with return code $status." >&2
                            echo "          Ignore and continue." >&2
                        }
                        fi
                    fi
                fi
            done
        else
            echo "==> Snapshot count within limit. No deletions needed."
        fi
    fi
fi

if [[ "$UPDATE_GRUB" == "true" ]] && command -v grub-mkconfig >/dev/null; then
    if [[ -d /etc/default/grub-btrfs ]] || [[ -f /usr/share/doc/grub-btrfs/README.md ]]; then
        echo "==> Updating GRUB config..."
        [[ "$DRY_RUN" == "true" ]] || grub-mkconfig -o /boot/grub/grub.cfg
    fi
fi

exit 0
